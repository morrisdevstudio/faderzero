{
  "name": "pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:audio": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-audio-worker.ps1",
    "build": "tsc -b && vite build",
    "build:deploy": "tsc -b && vite build --mode deploy",
    "deploy:test": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-pwa.ps1",
    "deploy:test:watch": "powershell -ExecutionPolicy Bypass -File ./scripts/watch-deploy-pwa.ps1",
    "lint": "oxlint",
    "preview": "vite preview",
    "security:headers": "node ./scripts/validate-security-headers.mjs",
    "security:secrets": "node ./scripts/scan-repository-secrets.mjs",
    "epic10:gate": "node ./scripts/validate-epic-10-gate.mjs",
    "test": "vitest run",
    "test:worker": "vitest run cloudflare/audio-worker/src/index.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:worker": "tsc --noEmit -p cloudflare/audio-worker/tsconfig.json"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@supabase/supabase-js": "2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "html5-qrcode": "^2.3.8",
    "lamejs": "^1.2.1",
    "lz-string": "^1.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
